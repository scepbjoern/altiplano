# docker-compose project name to isolate resources
COMPOSE_PROJECT_NAME=altiplano

# MCP Server Settings
# MCP_TRANSPORT can be: sse | streamable-http (default: stdio, but docker requires a network transport)
MCP_TRANSPORT=sse

# Host and Port binding for FastMCP inside the container
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=8000

# Port on the Docker host mapped to the container
APP_PORT=6274

# UID/GID under which the process inside the container runs (Default matches host user)
UID=1000
GID=1000

# DNS-Rebinding settings
# Set FASTMCP_DISABLE_DNS_REBINDING to true to disable FastMCP's DNS rebinding check
# (recommended if running behind Cloudflare Access / Reverse Proxies with domain names)
FASTMCP_DISABLE_DNS_REBINDING=true

# Or list allowed domains (comma-separated, wildcards allowed e.g. *.domain.local)
# FASTMCP_ALLOWED_HOSTS=altiplano.domain.local,*.mydomain.com

# Vikunja API Connection (Base API endpoint including /api/v1)
VIKUNJA_URL=https://vikunja.example.com/api/v1
VIKUNJA_API_TOKEN=tk_xxxxxxxxx

# Cloudflare Access (Optional service token credentials if Vikunja is behind Cloudflare Access)
# CF_CLIENT_ID=
# CF_CLIENT_SECRET=
